    <tr>
        <td style="padding: 10px; border-bottom: 1px solid #eee;"><strong>Department:</strong></td>
        <td style="padding: 10px; border-bottom: 1px solid #eee;">{{department}}</td>
    </tr>
    <tr>
        <td style="padding: 10px; border-bottom: 1px solid #eee;"><strong>Date & Time:</strong></td>
        <td style="padding: 10px; border-bottom: 1px solid #eee;">{{appointmentDate}}</td>
    </tr>
</table>
<p>Please arrive 15 minutes prior to your scheduled time.</p>
<p>Thank you for choosing City General Hospital.</p>
