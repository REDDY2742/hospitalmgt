# ==============================================================================
# HOSPITAL MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION (EXAMPLE)
# ==============================================================================
# This file defines all environment variables required for the backend infrastructure.
# Copy this file to '.env' and replace placeholders with real institutional values.
# Documentation: https://docs.hospital-hms.com/setup/environment

# === 1. APPLICATION CONFIG ===
NODE_ENV=development                # (string) [REQUIRED] development | production | staging | test
PORT=8000                           # (number) [REQUIRED] Main API port
APP_NAME="HMS Enterprise"           # (string) [REQUIRED] Institutional Name
APP_VERSION=1.0.0                   # (string) [REQUIRED] SemVer version
APP_URL=http://localhost:8000       # (url)    [REQUIRED] Base API URL
FRONTEND_URL=http://localhost:3000  # (url)    [REQUIRED] Hospital Admin Panel URL
API_VERSION=v1                      # (string) [REQUIRED] Version prefix
API_PREFIX=/api/v1                  # (string) [REQUIRED] Mount point
CORS_ORIGINS=http://localhost:3000,http://localhost:3001 # (csv) [REQUIRED] Allowed origins
ALLOWED_HOSTS=localhost,127.0.0.1   # (csv) [REQUIRED] Security host verification

# === 2. DATABASE (MySQL) ===
DB_HOST=127.0.0.1                   # (string) [REQUIRED] Database endpoint
DB_PORT=3306                        # (number) [REQUIRED] MySQL port
DB_NAME=hospital_db                 # (string) [REQUIRED] Database name
DB_USER=hms_admin                   # (string) [REQUIRED] Database username
DB_PASSWORD=your_secure_password    # (string) [REQUIRED] [SENSITIVE] Database password
DB_DIALECT=mysql                    # (string) [REQUIRED] Type of database
DB_POOL_MIN=5                       # (number) [OPTIONAL] Min connections
DB_POOL_MAX=20                      # (number) [OPTIONAL] Max connections
DB_POOL_ACQUIRE=30000               # (number) [OPTIONAL] Max time (ms) to wait for connection
DB_POOL_IDLE=10000                  # (number) [OPTIONAL] Max idle time (ms)
DB_LOGGING=false                    # (boolean) [OPTIONAL] Enable SQL query logging
DB_SSL=false                        # (boolean) [OPTIONAL] Enable SSL for production DB

# === 3. REDIS (Caching, Sessions & Locks) ===
REDIS_HOST=127.0.0.1                # (string) [REQUIRED] Redis server
REDIS_PORT=6379                     # (number) [REQUIRED] Redis port
REDIS_PASSWORD=null                 # (string) [OPTIONAL] [SENSITIVE] Redis password
REDIS_DB=0                          # (number) [OPTIONAL] Redis index for cache
REDIS_DB_SESSION=1                  # (number) [OPTIONAL] Redis index for sessions
REDIS_TTL=3600                      # (number) [OPTIONAL] Global cache TTL (seconds)
REDIS_URL=redis://localhost:6379    # (url)    [OPTIONAL] Connection string alternative

# === 4. IDENTITY & ACCESS (JWT) ===
JWT_ACCESS_SECRET=your_access_secret_key    # (string) [REQUIRED] [SENSITIVE] HMAC-SHA256
JWT_REFRESH_SECRET=your_refresh_secret_key  # (string) [REQUIRED] [SENSITIVE] HMAC-SHA256
JWT_ACCESS_EXPIRY=15m                       # (string) [REQUIRED] 15 minutes
JWT_REFRESH_EXPIRY=7d                       # (string) [REQUIRED] 7 days
JWT_ISSUER=hospital_v1                      # (string) [OPTIONAL] Token issuer ID
JWT_AUDIENCE=hospital_admin_webapp          # (string) [OPTIONAL] Intended client app

# === 5. AWS CLOUD STORAGE (S3) ===
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxx     # (string) [REQUIRED] [SENSITIVE]
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxx  # (string) [REQUIRED] [SENSITIVE]
AWS_REGION=ap-south-1                      # (string) [REQUIRED] e.g. Mumbai
AWS_S3_BUCKET_NAME=hms-clinical-docs       # (string) [REQUIRED] S3 bucket identifier
AWS_S3_BUCKET_URL=https://bucket.s3.url    # (url)    [OPTIONAL] Base URL
AWS_CLOUDFRONT_URL=https://d123.cloudfront.net # (url) [OPTIONAL] CDN URL
AWS_S3_SIGNED_URL_EXPIRY=3600              # (number) [OPTIONAL] Pre-signed URL expiry (secs)

# === 6. COMMUNICATION (Email) ===
# Nodemailer (Primary Staging/Internal)
SMTP_HOST=smtp.mailtrap.io          # (string) [OPTIONAL]
SMTP_PORT=2525                      # (number) [OPTIONAL]
SMTP_USER=user_id                   # (string) [OPTIONAL]
SMTP_PASS=password                  # (string) [OPTIONAL]
SMTP_SECURE=false                   # (boolean) [OPTIONAL]

# SendGrid (Production External)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx      # (string) [REQUIRED] [SENSITIVE]
EMAIL_FROM_NAME="Reddy Hospital Admin"    # (string) [REQUIRED] Display Name
EMAIL_FROM_ADDRESS=noreply@hospital.com   # (string) [REQUIRED] Clinical From Address
EMAIL_REPLY_TO=support@hospital.com       # (string) [OPTIONAL] Customer Service Address

# === 7. MOBILE MESSAGING (SMS) ===
# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxx    # (string) [REQUIRED] [SENSITIVE]
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxx    # (string) [REQUIRED] [SENSITIVE]
TWILIO_PHONE_NUMBER=++1234567890           # (string) [REQUIRED] Virtual number
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxx     # (string) [OPTIONAL] Bulk messaging profile

# === 8. FINANCIALS (Payment Gateway) ===
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx        # (string) [REQUIRED] [SENSITIVE]
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxx    # (string) [REQUIRED] [SENSITIVE]
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxx    # (string) [REQUIRED] [SENSITIVE]
PAYMENT_CURRENCY=INR                       # (string) [REQUIRED] Local Currency Code
PAYMENT_MODE=test                          # (string) [REQUIRED] test | live

# === 9. PUSH NOTIFICATIONS (Firebase) ===
FIREBASE_PROJECT_ID=hms-notif-v1           # (string) [REQUIRED]
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n" # (string) [SENSITIVE]
FIREBASE_CLIENT_EMAIL=admin@project.iam... # (string) [REQUIRED]
FIREBASE_DATABASE_URL=https://db.firebase.com # (url) [OPTIONAL]

# === 10. ERROR MONITORING (Sentry) ===
SENTRY_DSN=https://xxxxxxxx@sentry.io/123  # (url)    [OPTIONAL] Capture backend exceptions
SENTRY_ENVIRONMENT=production              # (string) [OPTIONAL] Error grouping name
SENTRY_TRACES_SAMPLE_RATE=1.0              # (number) [OPTIONAL] 0.0 to 1.0 (100% sampling)

# === 11. RATE LIMITING (Security) ===
RATE_LIMIT_WINDOW_MS=900000                # (number) [OPTIONAL] 15 mins
RATE_LIMIT_MAX_REQUESTS=200                # (number) [OPTIONAL] Max reqs per window
AUTH_RATE_LIMIT_MAX=5                      # (number) [OPTIONAL] Max login attempts
AUTH_RATE_LIMIT_WINDOW_MS=600000           # (number) [OPTIONAL] 10 mins

# === 12. FILE UPLOADS ===
MAX_FILE_SIZE_MB=5                         # (number) [REQUIRED] Limit per upload (Lab/Xray)
ALLOWED_FILE_TYPES=jpg,png,pdf,docx,xlsx   # (csv)    [REQUIRED] Extension whitelist
MAX_FILES_PER_REQUEST=5                    # (number) [OPTIONAL] Batch limit

# === 13. TELEMEDICINE (Video Sessions) ===
AGORA_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxx      # (string) [OPTIONAL] [SENSITIVE]
AGORA_APP_CERTIFICATE=xxxxxxxxxxxxxxxxxxx  # (string) [OPTIONAL] [SENSITIVE]
DAILY_CO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx  # (string) [OPTIONAL] [SENSITIVE]
DAILY_CO_DOMAIN=https://hospital.daily.co  # (url)    [OPTIONAL]

# === 14. DATA ENCRYPTION ===
ENCRYPTION_KEY=32chars_secure_encryption_key # (string) [REQUIRED] [SENSITIVE]
ENCRYPTION_ALGORITHM=aes-256-cbc           # (string) [REQUIRED] System standard
HASH_SALT_ROUNDS=12                        # (number) [REQUIRED] Bcrypt complexity

# === 15. LOGGING (Observability) ===
LOG_LEVEL=info                             # (string) [REQUIRED] debug | info | warn | error
LOG_DIR=logs                               # (string) [REQUIRED] Destination folder
LOG_MAX_SIZE=20m                           # (string) [OPTIONAL] Log rotation size
LOG_MAX_FILES=14d                          # (string) [OPTIONAL] Keep logs for 14 days
LOG_COMPRESS=true                          # (boolean) [OPTIONAL] zip old logs

# === 16. INSTITUTIONAL SCHEDULING ===
CRON_TIMEZONE=Asia/Kolkata                 # (string) [REQUIRED] Hospital Local Timezone
APPOINTMENT_REMINDER_HOURS_BEFORE=24       # (number) [OPTIONAL] When to send SMS
PHARMACY_EXPIRY_ALERT_DAYS=30              # (number) [OPTIONAL] Warn before medicine expires

# === 17. INSTITUTIONAL INFO ===
HOSPITAL_NAME="HMS Medical Center"         # (string) [REQUIRED] Official Name
HOSPITAL_CODE=HMC001                       # (string) [REQUIRED] Internal Prefix
HOSPITAL_ADDRESS="123 Care Street, City"   # (string) [REQUIRED] For Bills/Reports
HOSPITAL_PHONE=+919876543210               # (string) [REQUIRED] Support Number
HOSPITAL_EMAIL=contact@hospital.com        # (string) [REQUIRED] Helpdesk
HOSPITAL_WEBSITE=www.hospital.com          # (url)    [OPTIONAL] 
HOSPITAL_GST_NUMBER=22AAAAA0000A1Z5         # (string) [REQUIRED] Tax ID
HOSPITAL_LICENSE_NUMBER=LIC-12345-HMS      # (string) [REQUIRED] Clinical License

# === 18. PAGINATION CONFIG ===
DEFAULT_PAGE_SIZE=10                       # (number) [OPTIONAL] Dashboard defaults
MAX_PAGE_SIZE=100                          # (number) [OPTIONAL] Max fetch limit

# === 19. SECURITY (Session & Cookies) ===
BCRYPT_SALT_ROUNDS=12                      # (number) [REQUIRED]
OTP_EXPIRY_MINUTES=5                       # (number) [REQUIRED] OTP window
OTP_LENGTH=6                               # (number) [REQUIRED] e.g. 123456
SESSION_SECRET=a_very_long_session_secret  # (string) [REQUIRED] [SENSITIVE]
COOKIE_DOMAIN=.hospital.com                # (string) [OPTIONAL] Single Sign-On domain
COOKIE_SECURE=true                         # (boolean) [REQUIRED] Production HTTPS only

# === 20. FEATURE FLAGS (System Orchestration) ===
ENABLE_TELEMEDICINE=true                   # (boolean)
ENABLE_AMBULANCE_TRACKING=false            # (boolean)
ENABLE_INSURANCE_INTEGRATION=true          # (boolean)
ENABLE_PAYMENT_GATEWAY=true                # (boolean)
ENABLE_PUSH_NOTIFICATIONS=true             # (boolean)
ENABLE_SMS=true                            # (boolean)
ENABLE_EMAIL_VERIFICATION=true             # (boolean)
ENABLE_2FA=false                           # (boolean)
ENABLE_AUDIT_LOGS=true                     # (boolean) [CRITICAL] HIPAA Compliance
ENABLE_RATE_LIMITING=true                  # (boolean)
MAINTENANCE_MODE=false                     # (boolean) [DANGEROUS] Disables Public API
