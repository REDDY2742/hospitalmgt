# Application Environment
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_db
DB_USER=root
DB_PASSWORD=Lightfan@123

# Production SSL (required in production)
SSL_CERT_PATH=/path/to/ca-cert.pem

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 Buckets
S3_BUCKET_PATIENT_DOCUMENTS=hospital-patient-docs
S3_BUCKET_LAB_REPORTS=hospital-lab-reports
S3_BUCKET_PRESCRIPTIONS=hospital-prescriptions
S3_BUCKET_PROFILE_IMAGES=hospital-profile-images

# Redis Configuration
REDIS_MODE=single # single | cluster | sentinel
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SENTINEL_NAME=mymaster
REDIS_SENTINELS=127.0.0.1:26379,127.0.0.1:26380
REDIS_CLUSTER_NODES=127.0.0.1:7000,127.0.0.1:7001

# Mailer Configuration
MAIL_FROM=no-reply@cityhospital.com
FRONTEND_URL=https://hospital-portal.com
# Note: AWS_REGION and AWS credentials are already defined in AWS Configuration section

# Security
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_REFRESH_SECRET=your_long_lived_refresh_secret
ALLOWED_ORIGINS=http://localhost:3000,https://hospital-portal.com
INTERNAL_IPS=127.0.0.1,192.168.1.1
