# --- 1. NODE.JS DEPENDENCIES ---
node_modules/
.npm
.yarn
package-lock.json
# Note: package-lock.json is ignored to ensure environment-specific npm installs, 
# though some teams prefer tracking it for deterministic builds.

# --- 2. ENVIRONMENT & SECRETS ---

# (Keep .env.example tracked for documentation)

# --- 3. BUILD & DISTRIBUTION ---
dist/
build/
out/

# --- 4. LOGS & DIAGNOSTICS ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/**/*.log
logs/**/*.gz

# --- 5. UPLOADS & LOCAL STORAGE ---
uploads/
tmp/
temp/
*.tmp
*.temp

# --- 6. TEST COVERAGE & REPORTS ---
coverage/
.nyc_output/
jest_html_reporters/
junit.xml

# --- 7. OPERATING SYSTEM FILES ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- 8. IDE & EDITOR CONFIGS ---
.idea/
.vscode/
