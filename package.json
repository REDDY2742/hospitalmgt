{
  "name": "hospital-management-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade Hospital Management System REST API",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --inspect server.js",
    "dev:debug": "DEBUG=express:*,hms:* nodemon server.js",
    "build": "echo 'No build step required for Node.js'",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --thresholds 80",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "migrate:undo:all": "sequelize db:migrate:undo:all",
    "migrate:status": "sequelize db:migrate:status",
    "seed": "sequelize db:seed:all",
    "seed:undo": "sequelize db:seed:undo",
    "seed:undo:all": "sequelize db:seed:undo:all",
    "db:fresh": "sequelize db:migrate:undo:all && sequelize db:migrate && sequelize db:seed:all",
    "generate:migration": "sequelize migration:generate --name",
    "generate:seeder": "sequelize seed:generate --name",
    "docs:generate": "swagger-jsdoc -d swaggerDef.js -o ./src/config/swagger.json",
    "health:check": "curl -f http://localhost:8000/api/v1/health || exit 1",
    "docker:build": "docker build -t hospital-mgmt-backend .",
    "docker:run": "docker run -p 8000:8000 --env-file .env hospital-mgmt-backend",
    "logs:clear": "rm -rf logs/*.log",
    "audit:fix": "npm audit fix",
    "prepare": "husky install"
  },
  "keywords": [
    "hospital",
    "healthcare",
    "management",
    "erp",
    "api",
    "express"
  ],
  "author": "Antigravity HMS Architect",
  "license": "Proprietary",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@sendgrid/mail": "^7.7.0",
    "@sentry/node": "^7.0.0",
    "@socket.io/redis-adapter": "^8.0.0",
    "axios": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.0.0",
    "chalk": "^4.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.29.0",
    "dotenv": "^16.0.0",
    "exceljs": "^4.3.0",
    "express": "^4.18.0",
    "express-list-endpoints": "^6.0.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "express-slow-down": "^1.5.0",
    "firebase-admin": "^11.0.0",
    "helmet": "^6.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.0.0",
    "joi": "^17.7.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.0.0",
    "nanoid": "^3.3.4",
    "node-cron": "^3.0.2",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.13.0",
    "prom-client": "^14.1.0",
    "puppeteer": "^19.0.0",
    "qrcode": "^1.5.1",
    "rate-limit-redis": "^3.0.1",
    "razorpay": "^2.8.0",
    "redis": "^4.5.1",
    "sequelize": "^6.31.0",
    "slugify": "^1.6.5",
    "socket.io": "^4.6.0",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.2",
    "twilio": "^4.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@faker-js/faker": "^7.6.0",
    "eslint": "^8.30.0",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^8.0.0",
    "jest": "^29.3.0",
    "lint-staged": "^13.1.0",
    "nodemon": "^2.0.20",
    "prettier": "^2.8.0",
    "sequelize-cli": "^6.6.0",
    "supertest": "^6.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
        "src/**/*.js",
        "!src/config/*.js",
        "!src/routes/*.js"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/unit/**/*.test.js",
      "**/tests/integration/**/*.test.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended"
    ],
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "node/no-unsupported-features/es-syntax": "off"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hospital-management/backend.git"
  },
  "bugs": {
    "url": "https://github.com/hospital-management/backend/issues"
  },
  "homepage": "https://github.com/hospital-management/backend#readme"
}
